{
  "name": "autofixer",
  "displayName": "AutoFixer",
  "description": "Live autocorrect-style coding help for JavaScript and TypeScript",
  "version": "0.1.0",
  "publisher": "autofixer",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "keywords": [
    "autocorrect",
    "javascript",
    "typescript",
    "linting",
    "inline completions"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:typescript",
    "onLanguage:typescriptreact"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "autoFixer.toggle",
        "title": "AutoFixer: Toggle Enable/Disable"
      }
    ],
    "configuration": {
      "title": "AutoFixer",
      "properties": {
        "autoFixer.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable AutoFixer."
        },
        "autoFixer.debounceMs": {
          "type": "number",
          "default": 300,
          "minimum": 50,
          "maximum": 5000,
          "description": "Debounce delay in milliseconds before running diagnostics and completions."
        },
        "autoFixer.maxSuggestionsPerMinute": {
          "type": "number",
          "default": 30,
          "minimum": 1,
          "maximum": 300,
          "description": "Maximum number of inline completion suggestions per minute."
        },
        "autoFixer.styleMode": {
          "type": "string",
          "enum": [
            "safe",
            "aggressive"
          ],
          "default": "safe",
          "description": "Style mode: 'safe' for minimal suggestions, 'aggressive' for more suggestions."
        },
        "autoFixer.languages": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "javascript",
            "javascriptreact",
            "typescript",
            "typescriptreact"
          ],
          "description": "Languages that AutoFixer is active for."
        },
        "autoFixer.warnConsoleLog": {
          "type": "boolean",
          "default": true,
          "description": "Show a warning diagnostic for console.log statements."
        },
        "autoFixer.requireTodoOwner": {
          "type": "boolean",
          "default": true,
          "description": "Require TODO comments to have an owner tag, e.g. TODO(username)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
